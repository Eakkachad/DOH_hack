# Ignore machine-specific config
/config/*
!/config/.gitkeep

# Ignore processing and failed raw files to avoid syncing intermediate states
/raw/processing/*
!/raw/processing/.gitkeep
/raw/inbox/*
!/raw/inbox/.gitkeep

# Ignore environment variables
.env
.env.local

# Obsidian workspace files
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
